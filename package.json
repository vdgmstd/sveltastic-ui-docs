{
	"name": "sveltastic-ui-docs",
	"version": "1.0.4",
	"private": true,
	"description": "Documentation site and playground for sveltastic-ui.",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0 --port 5001 --strictPort",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test --project=chromium --project=firefox",
		"test:e2e:all": "playwright test",
		"prepare": "svelte-kit sync || echo ''"
	},
	"dependencies": {
		"phosphor-svelte": "^3.1.0",
		"sveltastic-ui": "file:../ui",
		"svelte": "^5.55.8",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.0",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"vite": "^8.0.13"
	}
}
